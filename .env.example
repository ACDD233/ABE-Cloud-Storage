# MariaDB Configuration
# Set the root password for the database
DB_ROOT_PASSWORD=my_secret_root_password

# Database name, user and password for the application
DB_NAME=abe_cloud_disk
DB_USER=abe_user
DB_PASSWORD=abe_user_password

# Application Configuration
# Inside the container, this is the directory where files are uploaded
UPLOAD_DIR=/app/uploads

# Secret key used for JWT token generation. Should be a long, random string.
JWT_SECRET=your_super_secret_jwt_key_that_is_at_least_256_bits_long
